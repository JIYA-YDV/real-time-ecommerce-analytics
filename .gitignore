# ============================================
# Spark & Hadoop
# ============================================
# Checkpoint directories (contains binary state)
**/checkpoint/
**/checkpoints/
checkpoint/
checkpoints/

# Spark event logs
spark-warehouse/
derby.log
metastore_db/
*.log

# ============================================
# Large JAR Files (GitHub 100MB limit)
# ============================================
# AWS SDK is 267MB - too large for GitHub
**/jars/aws-java-sdk-bundle-*.jar
Stage-2-Spark/jars/aws-java-sdk-bundle-*.jar

# Alternatively: Ignore ALL JARs, then add exceptions
# **/jars/*.jar
# !**/jars/hadoop-aws-*.jar
# !**/jars/kafka-clients-*.jar
# !**/jars/commons-pool2-*.jar
# !**/jars/spark-sql-kafka-*.jar
# !**/jars/spark-token-provider-*.jar

