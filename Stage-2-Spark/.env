# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=orders.raw
KAFKA_FRAUD_TOPIC=fraud.alerts

# MinIO (S3) Configuration
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PROCESSED=orders-processed
S3_BUCKET_RAW=orders-raw

# Spark Configuration
SPARK_APP_NAME=EcommerceStreamingPipeline
CHECKPOINT_LOCATION=./checkpoint
LOG_LEVEL=WARN

# Fraud Detection Rules
FRAUD_AMOUNT_THRESHOLD=1000
FRAUD_TENURE_THRESHOLD=30

# Window Configuration
WINDOW_DURATION=5 minutes
WATERMARK_DELAY=10 minutes
TRIGGER_INTERVAL=5 seconds